{
  "seed": 7,
  "output_dir": "outputs/v2_smoke",
  "device": "auto",
  "data": {
    "batch_size": 2,
    "num_workers": 0,
    "pin_memory": false,
    "drop_last": false,
    "scales": {
      "fine_to_mid": 2,
      "fine_to_coarse": 4,
      "pooling_mode": "avg"
    },
    "mask": {
      "pattern": "random",
      "missing_rate": 0.45
    },
    "synthetic": {
      "num_train": 8,
      "num_val": 4,
      "t": 6,
      "h": 16,
      "w": 16
    }
  },
  "model": {
    "c_in": 2,
    "main": {
      "dim": 16,
      "num_experts": 2,
      "top_k": 1,
      "max_t": 8,
      "h": 16,
      "w": 16,
      "q_dim": 5,
      "num_groups": 4,
      "dropout": 0.0,
      "use_multiscale": true,
      "use_router": true,
      "share_experts": true,
      "use_routed_branch": true,
      "use_shared_branch": true,
      "shared_input_mode": "pre",
      "shared_expert_beta_init": 0.1,
      "detach_shared_expert_input": false,
      "branch_fusion_mode": "residual",
      "branch_gate_init": "balanced",
      "route_gamma_init": -3.0,
      "route_dropout": 0.1,
      "enable_branch_aux": true,
      "enable_complementary_loss": true,
      "routing_mode": "topk",
      "routing_mode_when_no_router": "dense",
      "router_granularity": "sample",
      "use_scale_gate": true,
      "use_reliability_gate": true,
      "scale_mode": "fine_mid_coarse"
    },
    "aux": {
      "enabled": false,
      "alpha_init": 0.0
    }
  },
  "loss": {
    "type": "smooth_l1",
    "lambda_cross": 0.1,
    "lambda_balance": 0.01,
    "lambda_importance_balance": 0.01,
    "lambda_load_balance": 0.01,
    "lambda_shared_aux": 0.05,
    "lambda_route_aux": 0.1,
    "lambda_complementary": 0.003,
    "lambda_fusion_entropy": 0.0,
    "lambda_branch_entropy": 0.0,
    "lambda_final": 0.0
  },
  "train": {
    "epochs": 1,
    "lr_main": 0.0005,
    "lr_aux": 0.0005,
    "weight_decay": 0.0001,
    "gate_lr_mult": 1.0,
    "scalar_lr_mult": 2.0,
    "aux_loss_warmup_epochs": 1,
    "grad_clip_norm": 1.0,
    "amp": true,
    "save_every": 1
  }
}
